@model IEnumerable<SportMania.Models.Plan>
@{
    ViewData["Title"] = "Home";
}

<section class="hero text-center py-5">
    <div class="container">
        <h1 class="display-5 fw-bold text-gradient">Stream Your Favorite <br />Content Anytime</h1>
        <p class="lead text-secondary mt-3 mx-auto" style="max-width: 760px;">
            Get unlimited access to thousands of movies, series, and exclusive content. Choose a plan that fits your
            lifestyle and start streaming today.
        </p>
    </div>
</section>

<section class="pricing py-4">
    <div class="container">
        <div class="row text-center">
            <div class="col-12 mb-4 d-flex justify-content-center align-items-center gap-2">
                <h2 class="h4 text-light mb-0">Choose Your Plan</h2>
                <div class="badge bg-dark-subtle text-secondary text-black">Mock Mode</div>
            </div>
        </div>
        <div class="row g-4 justify-content-center">
            @foreach (var plan in Model)
            {
                <div class="col-12 col-md-4">
                    <div
                        class="pricing-card h-100 @(plan.Name.Contains("Monthly", StringComparison.OrdinalIgnoreCase) ? "featured" : "")">
                        @if (plan.Name.Contains("Monthly", StringComparison.OrdinalIgnoreCase))
                        {
                            <div class="badge badge-most-popular">Most Popular</div>
                        }
                        <div class="pricing-card-header text-center d-flex flex-column align-items-center">
                            <img src="@plan.ImageUrl" alt="@plan.Name" class="rounded mb-2"
                                style="width:40px;height:40px;object-fit:cover;" />
                            <span class="h4 fw-semibold">@plan.Name</span>
                        </div>
                        <div class="h6 text-secondary text-center mb-3">@plan.Description</div>
                        <div class="price text-center">
                            <span class="amount">@plan.Price</span><span class="period">/@plan.Duration</span>
                        </div>
                        <ul class="list-unstyled mt-3 mb-4 text-secondary">
                            @foreach (var d in plan.Details)
                            {
                                <li>✅ @d.Value</li>
                            }
                        </ul>
                        <a class="btn btn-accent w-100" asp-controller="Home" asp-action="Index">Subscribe Now</a>
                    </div>
                </div>
            }
        </div>
    </div>
</section>