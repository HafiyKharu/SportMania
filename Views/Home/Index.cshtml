@model IEnumerable<SportMania.Models.Plan>
@{
    ViewData["Title"] = "Home";
}

<section class="hero text-center py-5">
    <div class="container">
        <h1 class="display-5 fw-bold text-white">Stream Your Favorite </h1>
        <h1 class="display-5 fw-bold text-gradient">Content Anytime</h1>
        <p class="lead text-secondary mt-3 mx-auto" style="max-width: 760px;">
            Get unlimited access to thousands of movies, series, and exclusive content. Choose a plan that fits your
            lifestyle and start streaming today.
        </p>
    </div>
</section>

<section class="pricing py-4">
    <div class="container">
        <div class="row text-center">
            <div class="col-12 mb-4 d-flex justify-content-center align-items-center gap-2">
                <h2 class="h4 text-light mb-0">Choose Your Plan</h2>
                <div class="badge bg-dark-subtle text-secondary text-black">Mock Mode</div>
            </div>
        </div>
        <div class="row g-4 justify-content-center">
            @foreach (var plan in Model)
            {
                var isPopular = plan.Name.Contains("Monthly", StringComparison.OrdinalIgnoreCase);
                <div class="col-12 col-md-4">
                    <div class="card h-100 bg-black text-center position-relative @(isPopular ? "border-primary" : "")"
                         style="transition:transform .3s ease, box-shadow .3s ease;"
                         onmouseover="this.style.transform='scale(1.03)'; this.classList.add('shadow');"
                         onmouseout="this.style.transform=''; this.classList.remove('shadow');">

                        @if (isPopular)
                        {
                            <div class="position-absolute start-50 translate-middle-x" style="top:-12px;">
                                <span class="badge rounded-pill bg-primary text-white px-3 py-1 small">Most Popular</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="mx-auto mb-3 d-flex align-items-center justify-content-center rounded-circle"
                                 style="width:56px;height:56px;background-color:rgba(13,110,253,.1);">
                                <img src="@plan.ImageUrl" alt="@plan.Name" class="rounded-circle"
                                     style="width:28px;height:28px;object-fit:cover;" />
                            </div>

                            <h5 class="card-title h4 fw-semibold text-white">@plan.Name</h5>
                            <p class="card-text text-secondary mb-3">@plan.Description</p>

                            <div class="mb-3">
                                <span class="fs-2 fw-bold text-light">@plan.Price</span>
                                <span class="text-secondary">/@plan.Duration</span>
                            </div>

                            <ul class="list-unstyled text-start mx-3">
                                @foreach (var d in plan.Details)
                                {
                                    <li class="d-flex align-items-center gap-2 mb-2">
                                        <svg class="text-primary flex-shrink-0" style="width:16px;height:16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                        </svg>
                                        <span class="small text-secondary">@d.Value</span>
                                    </li>
                                }
                            </ul>
                        </div>

                        <div class="card-footer text-muted bg-transparent border-0 py-4">
                            <button class="btn w-100 @(isPopular ? "btn-primary" : "btn-secondary")"
                                    data-bs-toggle="modal" data-bs-target="#emailModal" data-plan-id="@plan.PlanId" data-plan-name="@plan.Name">
                                Subscribe Now
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Email Modal -->
<div class="modal fade" id="emailModal" tabindex="-1" aria-labelledby="emailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-black border-secondary">
            <div class="modal-header">
                <h5 class="modal-title" id="emailModalLabel">Subscribe to <span id="planName"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="Transaction" asp-action="InitiatePayment" method="post">
                <div class="modal-body">
                    <input type="hidden" id="planId" name="PlanId" />
                    <input type="hidden" name="GuildId" value="763394782998560788" />
                    <div class="mb-3">
                        <label for="email" class="form-label">Email address</label>
                        <input type="email" class="form-control" id="email" name="Email" placeholder="you@example.com" required>
                    </div>
                    <div class="mb-3">
                        <label for="phone" class="form-label">Phone Number</label>
                        <input type="tel" class="form-control" id="phone" name="Phone" placeholder="0123456789" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary">Proceed to Payment</button>
                </div>
            </form>
        </div>
    </div>
</div>