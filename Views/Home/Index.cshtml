@model IEnumerable<SportMania.Models.Plan>
@{
    ViewData["Title"] = "SportManiaMY - Watch Your Favorite Sports Live";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'brand-blue': '#2B7FFF',
                        'brand-purple': '#AD46FF',
                        'brand-pink': '#F6339A',
                    },
                    fontFamily: {
                        'arimo': ['Arimo', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        .bg-gradient-primary {
            background: linear-gradient(90deg, #2B7FFF 0%, #AD46FF 100%);
        }
        .bg-gradient-secondary {
            background: linear-gradient(135deg, rgba(16, 24, 40, 0.5) 0%, rgba(3, 7, 18, 0.5) 100%);
        }
        .bg-gradient-card {
            background: linear-gradient(135deg, rgba(43, 127, 255, 0.1) 0%, rgba(173, 70, 255, 0.1) 100%);
        }
        .text-gradient {
            background: linear-gradient(90deg, #51A2FF 0%, #C27AFF 50%, #FBA4D6 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .shadow-glow {
            box-shadow: 0px 4px 6px -4px rgba(43, 127, 255, 0.25), 0px 10px 15px -3px rgba(43, 127, 255, 0.25);
        }
    .blur-bg {
        filter: blur(128px);
    }

    /* Modal backdrop blur effect */
    .modal-backdrop {
        background-color: rgba(0, 0, 0, 0.8) !important;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
    }

    /* Ensure modal is always on top */
    .modal {
        z-index: 1055;
    }

    .modal-backdrop {
        z-index: 1050;
    }
    </style>
</head>
<body class="bg-black text-white font-arimo">

<!-- Navigation -->
<nav class="fixed top-0 w-full z-50 bg-black/50 backdrop-blur-sm border-b border-gray-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
            <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-gradient-primary rounded-lg flex items-center justify-center blur-bg">
                    <span class="text-white font-bold text-sm">SM</span>
                </div>
                <span class="text-gradient font-bold text-xl">SportManiaMY</span>
            </div>
            <button class="bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-sm font-medium hover:bg-white/10 transition-colors">
                Login
            </button>
        </div>
    </div>
</nav>

<!-- Hero Section -->
<section class="relative pt-24 pb-12 overflow-hidden">
    <!-- Background Effects -->
    <div class="absolute inset-0">
        <div class="absolute top-6 left-0 w-80 h-80 bg-brand-blue rounded-full blur-bg opacity-10"></div>
        <div class="absolute top-0 right-0 w-96 h-96 bg-brand-purple rounded-full blur-bg opacity-10"></div>
        <div class="absolute bottom-20 left-20 w-72 h-72 bg-brand-pink rounded-full blur-bg opacity-10"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-8">
            <!-- 4K Badge -->
            <div class="inline-flex items-center px-4 py-2 bg-gradient-card border border-brand-blue/20 rounded-full text-sm font-medium text-gray-300 mb-8">
                <div class="w-4 h-4 bg-gradient-primary rounded mr-2"></div>
                Now streaming in 4K Ultra HD
            </div>

            <!-- Main Heading -->
            <h1 class="text-6xl md:text-7xl font-bold mb-6 leading-tight">
                Watch Your Favorite<br>
                <span class="text-gradient">Sports Live</span>
            </h1>

            <!-- Description -->
            <p class="text-gray-400 text-xl max-w-3xl mx-auto mb-12 leading-relaxed">
                Stream premium sports content with crystal-clear quality. Join thousands of fans already enjoying unlimited access to live matches and exclusive content.
            </p>

            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
                <button class="bg-gradient-primary hover:shadow-glow transition-all duration-300 px-8 py-4 rounded-xl font-bold text-lg">
                    Get Started Now
                </button>
                <button class="bg-white/5 border border-white/10 hover:bg-white/10 transition-colors px-8 py-4 rounded-xl font-semibold text-lg">
                    View Plans
                </button>
            </div>

            <!-- Stats -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-2xl mx-auto">
                <div class="text-center">
                    <div class="text-4xl font-bold text-gradient mb-2">10K+</div>
                    <div class="text-gray-500">Active Users</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl font-bold text-gradient mb-2">99.9%</div>
                    <div class="text-gray-500">Uptime</div>
                </div>
                <div class="text-center">
                    <div class="text-4xl font-bold text-gradient mb-2">4K</div>
                    <div class="text-gray-500">HD Quality</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Premium Quality -->
            <div class="bg-gradient-secondary border border-gray-800/50 rounded-xl p-8 hover:border-brand-blue/30 transition-colors">
                <div class="w-12 h-12 bg-gradient-card rounded-lg flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <h3 class="text-xl font-bold mb-4">Premium Quality</h3>
                <p class="text-gray-400 leading-relaxed">Stream in up to 4K Ultra HD with zero buffering</p>
            </div>

            <!-- Secure Payment -->
            <div class="bg-gradient-secondary border border-gray-800/50 rounded-xl p-8 hover:border-brand-blue/30 transition-colors">
                <div class="w-12 h-12 bg-gradient-card rounded-lg flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                    </svg>
                </div>
                <h3 class="text-xl font-bold mb-4">Secure Payment</h3>
                <p class="text-gray-400 leading-relaxed">Protected by ToyyibPay, Malaysia's trusted gateway</p>
            </div>

            <!-- Instant Access -->
            <div class="bg-gradient-secondary border border-gray-800/50 rounded-xl p-8 hover:border-brand-blue/30 transition-colors">
                <div class="w-12 h-12 bg-gradient-card rounded-lg flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </div>
                <h3 class="text-xl font-bold mb-4">Instant Access</h3>
                <p class="text-gray-400 leading-relaxed">Get your access code immediately after payment</p>
            </div>

            <!-- 24/7 Support -->
            <div class="bg-gradient-secondary border border-gray-800/50 rounded-xl p-8 hover:border-brand-blue/30 transition-colors">
                <div class="w-12 h-12 bg-gradient-card rounded-lg flex items-center justify-center mb-6">
                    <svg class="w-6 h-6 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192L5.636 18.364M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                </div>
                <h3 class="text-xl font-bold mb-4">24/7 Support</h3>
                <p class="text-gray-400 leading-relaxed">Always here to help via Discord or email</p>
            </div>
        </div>
    </div>
</section>

<!-- Pricing Section -->
<section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-5xl font-bold mb-6">Choose Your Plan</h2>
            <p class="text-gray-400 text-xl max-w-2xl mx-auto">
                Select the perfect plan for your streaming needs. All plans include full access to our premium content.
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
            @foreach (var plan in Model)
            {
                var isPopular = plan.Name.Contains("Monthly", StringComparison.OrdinalIgnoreCase);
                var isWeekly = plan.Name.Contains("Weekly", StringComparison.OrdinalIgnoreCase);
                var isSeason = plan.Name.Contains("Season", StringComparison.OrdinalIgnoreCase);
                var durationLower = plan.Duration.ToLower();

                <div class="relative @(isPopular ? "lg:scale-105 lg:-mt-4" : "")">
                    @if (isPopular)
                    {
                        <!-- Most Popular Badge -->
                        <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 z-10">
                            <div class="bg-gradient-primary px-4 py-2 rounded-full flex items-center gap-2 text-sm font-bold">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"/>
                                </svg>
                                MOST POPULAR
                            </div>
                        </div>
                    }

                    <div class="bg-gradient-secondary border border-gray-800/50 rounded-xl p-8 h-full hover:border-brand-blue/30 transition-all duration-300 @(isPopular ? "ring-2 ring-brand-blue/20" : "")">
                        <!-- Icon -->
                        <div class="w-16 h-16 bg-gradient-card rounded-xl flex items-center justify-center mx-auto mb-6">
                            <img src="@plan.ImageUrl" alt="@plan.Name" class="w-8 h-8 rounded-lg object-cover" />
                        </div>

                        <!-- Plan Name -->
                        <h3 class="text-2xl font-bold text-center mb-2">@plan.Name</h3>
                        <p class="text-gray-400 text-center mb-6">@plan.Description</p>

                        <!-- Price -->
                        <div class="text-center mb-8">
                            <div class="text-5xl font-bold text-gradient mb-2">@plan.Price</div>
                            <div class="text-gray-500">/@plan.Duration</div>
                        </div>

                        <!-- Features -->
                        <ul class="space-y-4 mb-8">
                            @foreach (var detail in plan.Details)
                            {
                                <li class="flex items-start gap-3">
                                    <svg class="w-5 h-5 text-brand-blue mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                    <span class="text-gray-300">@detail.Value</span>
                                </li>
                            }
                        </ul>

                        <!-- CTA Button -->
                        <button class="w-full @(isPopular ? "bg-gradient-primary hover:shadow-glow" : "bg-white/5 border border-white/10 hover:bg-white/10") transition-all duration-300 py-4 rounded-xl font-bold text-lg"
                                data-bs-toggle="modal" data-bs-target="#emailModal" data-plan-id="@plan.PlanId" data-plan-name="@plan.Name" data-plan-price="@plan.Price" data-plan-duration="@durationLower">
                            Get Started
                        </button>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-12">
            <p class="text-gray-500">
                All payments are processed securely through ToyyibPay • No hidden fees • Cancel anytime
            </p>
        </div>
    </div>
</section>

<!-- Footer -->
<footer class="border-t border-gray-800/50 py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-4">
            <div class="text-gray-500">
                Powered by ToyyibPay - Malaysia's trusted payment gateway
            </div>
            <div class="flex gap-6 text-sm">
                <a href="#" class="text-gray-400 hover:text-white transition-colors">Privacy Policy</a>
                <a href="#" class="text-gray-400 hover:text-white transition-colors">Terms of Service</a>
                <a href="#" class="text-gray-400 hover:text-white transition-colors">Contact Support</a>
            </div>
        </div>
    </div>
</footer>

<!-- Payment Modal -->
<div class="modal fade" id="emailModal" tabindex="-1" aria-labelledby="emailModalLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content bg-black border border-gray-700 rounded-xl shadow-2xl">
            <!-- Modal Header -->
            <div class="border-b border-gray-800 p-6">
                <div class="flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <!-- Icon -->
                        <div class="w-12 h-12 bg-gradient-primary rounded-xl flex items-center justify-center">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-white">Complete Your Purchase</h2>
                            <p class="text-gray-400 text-sm">Secure checkout powered by ToyyibPay</p>
                        </div>
                    </div>
                    <button type="button" class="text-gray-400 hover:text-white transition-colors" data-bs-dismiss="modal" aria-label="Close">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Selected Plan Section -->
            <div class="bg-gradient-card border-b border-gray-800 p-6">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-gray-400 text-sm mb-1">Selected Plan</p>
                        <h3 class="text-xl font-bold text-white" id="planName">Monthly Plan</h3>
                    </div>
                    <div class="text-right">
                        <div class="text-3xl font-bold text-gradient" id="planPrice">RM10.00</div>
                        <div class="text-gray-500 text-sm" id="planDuration">/month</div>
                    </div>
                </div>
            </div>

            <form asp-controller="Transaction" asp-action="InitiatePayment" method="post">
                <input type="hidden" id="planId" name="PlanId" />

                <!-- Form Section -->
                <div class="p-6 space-y-6">
                    <!-- Email Field -->
                    <div class="space-y-2">
                        <label class="flex items-center gap-3 text-gray-300 font-medium">
                            <svg class="w-4 h-4 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                            Email Address
                        </label>
                        <input type="email" class="w-full px-4 py-3 bg-gray-900/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:border-brand-blue focus:ring-1 focus:ring-brand-blue transition-colors" id="email" name="Email" placeholder="your.email@example.com" required>
                        <p class="text-gray-500 text-xs">Your access code will be sent here</p>
                    </div>

                    <!-- Phone Field -->
                    <div class="space-y-2">
                        <label class="flex items-center gap-3 text-gray-300 font-medium">
                            <svg class="w-4 h-4 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                            Phone Number
                        </label>
                        <input type="tel" class="w-full px-4 py-3 bg-gray-900/50 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:border-brand-blue focus:ring-1 focus:ring-brand-blue transition-colors" id="phone" name="Phone" placeholder="0123456789" required>
                    </div>

                    <!-- Security Info -->
                    <div class="bg-gray-900/30 border border-gray-700/50 rounded-xl p-4">
                        <div class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-green-400 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                            </svg>
                            <div>
                                <h4 class="text-white font-medium mb-1">Secure Payment</h4>
                                <p class="text-gray-400 text-sm leading-relaxed">
                                    Your payment is processed securely through ToyyibPay, a trusted Malaysian payment gateway. We never store your payment information.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- What Happens Next -->
                    <div class="bg-gradient-card border border-brand-blue/20 rounded-xl p-4">
                        <h4 class="text-white font-medium mb-4">What happens next:</h4>
                        <div class="space-y-3">
                            <div class="flex items-center gap-3">
                                <div class="w-5 h-5 bg-brand-blue/20 rounded-full flex items-center justify-center flex-shrink-0">
                                    <svg class="w-3 h-3 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                </div>
                                <span class="text-gray-300 text-sm">Payment processed via ToyyibPay</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-5 h-5 bg-brand-blue/20 rounded-full flex items-center justify-center flex-shrink-0">
                                    <svg class="w-3 h-3 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                </div>
                                <span class="text-gray-300 text-sm">Access code sent to your email</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-5 h-5 bg-brand-blue/20 rounded-full flex items-center justify-center flex-shrink-0">
                                    <svg class="w-3 h-3 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                </div>
                                <span class="text-gray-300 text-sm">Join Discord and use /redeem command</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-5 h-5 bg-brand-blue/20 rounded-full flex items-center justify-center flex-shrink-0">
                                    <svg class="w-3 h-3 text-brand-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                </div>
                                <span class="text-gray-300 text-sm">Start streaming immediately</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="border-t border-gray-800 p-6">
                    <div class="flex gap-3">
                        <button type="button" class="flex-1 px-6 py-3 bg-gray-800 hover:bg-gray-700 text-white rounded-xl font-medium transition-colors" data-bs-dismiss="modal">
                            Cancel
                        </button>
                        <button type="submit" class="flex-1 px-6 py-3 bg-gradient-primary hover:shadow-glow text-white rounded-xl font-bold transition-all">
                            Pay <span id="payAmount">RM10.00</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Modal functionality
    const emailModal = document.getElementById('emailModal');
    emailModal.addEventListener('show.bs.modal', function (event) {
        const button = event.relatedTarget;
        const planId = button.getAttribute('data-plan-id');
        const planName = button.getAttribute('data-plan-name');
        const planPrice = button.getAttribute('data-plan-price');
        const planDuration = button.getAttribute('data-plan-duration');

        // Update modal content
        document.getElementById('planId').value = planId;
        document.getElementById('planName').textContent = planName;
        document.getElementById('planPrice').textContent = planPrice;
        document.getElementById('planDuration').textContent = '/' + planDuration;
        document.getElementById('payAmount').textContent = planPrice;
    });
</script>

</body>
</html>