@model IEnumerable<SportMania.Models.Transaction>
@{
    ViewData["Title"] = "Transaction History";
}

<div class="container py-5">
    <h1 class="mb-4">Transaction History</h1>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="thead-dark">
                        <tr>
                            <th>Transaction ID</th>
                            <th>Customer Email</th>
                            <th>Plan</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Key</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var transaction in Model)
                            {
                                <tr>
                                    <td><small>@transaction.TransactionId</small></td>
                                    <td>@transaction.Customer.Email</td>
                                    <td>@transaction.Plan.Name</td>
                                    <td>$@transaction.Amount</td>
                                    <td>
                                        <span class="badge @(transaction.PaymentStatus == "Success" ? "bg-success" : (transaction.PaymentStatus == "Pending" ? "bg-warning text-dark" : "bg-danger"))">
                                            @transaction.PaymentStatus
                                        </span>
                                    </td>
                                    <td>@(transaction.Key?.Code ?? "N/A")</td>
                                    <td>@transaction.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center">No transactions found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>