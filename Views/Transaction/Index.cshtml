@model IEnumerable<SportMania.Models.Transaction>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@{
    ViewData["Title"] = "Transaction History";
}

@if (SignInManager.IsSignedIn(User))
{
    <div class="container py-5">
        <h1 class="mb-4">Transaction History</h1>

        <div class="card bg-dark text-white">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-dark table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Transaction ID</th>
                                <th>Email</th>
                                <th>Phone Number</th>
                                <th>Plan</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Key</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var transaction in Model)
                                {
                                    <tr>
                                        <td><small>@transaction.TransactionId</small></td>
                                        <td>@transaction.Customer.Email</td>
                                        <td>@transaction.Plan.Name</td>
                                        <td>@transaction.Amount</td>
                                        <td>
                                            <span
                                                class="badge @(transaction.PaymentStatus == "Success" ? "bg-success" : (transaction.PaymentStatus == "Pending" ? "bg-warning text-dark" : "bg-danger"))">
                                                @transaction.PaymentStatus
                                            </span>
                                        </td>
                                        <td>@(transaction.Key?.Code ?? "N/A")</td>
                                        <td>@transaction.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">No transactions found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-warning text-center" role="alert">
        Please <a asp-area="Identity" asp-page="/Account/Login" class="alert-link">log in</a> to view your transaction history.
    </div>
}