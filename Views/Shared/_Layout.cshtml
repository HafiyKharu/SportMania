
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportMania</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SportMania.styles.css" asp-append-version="true" />
</head>
<body class="theme-dark">
    <header class="sticky-top w-100 bg-black">
        <div class="container d-flex align-items-center justify-content-between py-2">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="d-flex align-items-center gap-2 text-decoration-none">
                <div class="d-flex align-items-center justify-content-center rounded bg-primary" style="width:36px;height:36px;">
                    <!-- Play icon (SVG) -->
                    <svg class="text-dark" style="width:20px;height:20px;fill:currentColor;" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M8 5v14l11-7-11-7z"></path>
                    </svg>
                </div>
                <span class="fs-5 fw-bold text-white">StreamFlix</span>
            </a>
            <ul class="navbar-nav">
                <partial name="_LoginPartial" />
            </ul>
        </div>
    </header>
    <div class="container-xl">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top-0 footer text-muted bg-black">
        <div class="container-xl small text-secondary">
            Powered by ToyyibPay - A secure Malaysian payment gateway<a class="text-light" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
