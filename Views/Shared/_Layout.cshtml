
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportMania</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Arimo:wght@400;700&display=swap" rel="stylesheet">
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SportMania.styles.css" asp-append-version="true" />
    <style>
        .gradient-text {
            background: linear-gradient(90deg, #51A2FF 0%, #C27AFF 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .gradient-button {
            background: linear-gradient(90deg, #155DFC 0%, #9810FA 100%);
        }
        .glassmorphic {
            background: linear-gradient(135deg, rgba(16, 24, 40, 0.9) 0%, rgba(3, 7, 18, 0.9) 100%);
            border: 1px solid #1E2939;
        }
        .blur-circle-blue {
            background: #2B7FFF;
            filter: blur(128px);
            opacity: 0.1;
        }
        .blur-circle-purple {
            background: #AD46FF;
            filter: blur(128px);
            opacity: 0.1;
        }
        .blur-circle-pink {
            background: #F6339A;
            filter: blur(128px);
            opacity: 0.1;
        }
        .button-shadow {
            box-shadow: 0px 4px 6px -4px rgba(43, 127, 255, 0.25), 0px 10px 15px -3px rgba(43, 127, 255, 0.25);
        }
        body {
            font-family: 'Arimo', sans-serif;
        }
    </style>
</head>
<body class="theme-dark">
    <header class="sticky-top w-100 bg-black">
        <div class="container d-flex align-items-center justify-content-between py-2">
            <a asp-area="" asp-controller="Home" asp-action="Index" class="d-flex align-items-center gap-2 text-decoration-none">
                <div class="d-flex align-items-center justify-content-center rounded bg-primary" style="width:36px;height:36px;">
                    <!-- Play icon (SVG) -->
                    <svg class="text-dark" style="width:20px;height:20px;fill:currentColor;" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M8 5v14l11-7-11-7z"></path>
                    </svg>
                </div>
                <span class="fs-5 fw-bold text-white">SportMania MY</span>
            </a>
            <ul class="navbar-nav">
                <partial name="_LoginPartial" />
            </ul>
        </div>
    </header>
    <div class="container-xl py-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top-0 footer text-muted bg-black">
        <div class="container-xl small text-secondary">
            Powered by ToyyibPay - A secure Malaysian payment gateway   <a class="text-light" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
