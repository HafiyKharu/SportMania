@model SportMania.Models.Plan
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Edit Plan";
}

@if (!SignInManager.IsSignedIn(User))
{
    <div class="alert alert-warning text-center" role="alert">
        Please <a asp-area="Identity" asp-page="/Account/Login" class="alert-link">log in</a> to edit this plan.
    </div>
}
else
{
    <h2>Edit Plan</h2>

    <form asp-action="Edit" asp-route-id="@Model.PlanId" method="post">
        <input type="hidden" asp-for="PlanId" />

        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description" class="control-label"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Price" class="control-label"></label>
            <textarea asp-for="Price" class="form-control"></textarea>
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Duration" class="control-label"></label>
            <textarea asp-for="Duration" class="form-control"></textarea>
            <span asp-validation-for="Duration" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label class="control-label">Details</label>
            <div id="details-list">
                @if (Model?.Details != null && Model.Details.Count > 0)
                {
                    for (var i = 0; i < Model.Details.Count; i++)
                    {
                        <div class="input-group mb-2" data-index="@i">
                            <input type="hidden" name="Details[@i].Id" value="@Model.Details[i].PlanDetailsId" />
                            <input type="text" name="Details[@i].Value" value="@Model.Details[i].Value" class="form-control"
                                placeholder="Value" />
                            <button type="button" class="btn btn-outline-danger remove-detail">Remove</button>
                        </div>
                    }
                }
                else
                {
                    <div class="input-group mb-2" data-index="0">
                        <input type="hidden" name="Details[0].Id" value="" />
                        <input type="text" name="Details[0].Value" class="form-control" placeholder="Value" />
                        <button type="button" class="btn btn-outline-danger remove-detail">Remove</button>
                    </div>
                }
            </div>
            <button type="button" id="add-detail" class="btn btn-outline-accent mt-2">Add Detail</button>
        </div>

        <div class="form-group">
            <label asp-for="ImageUrl" class="control-label">Image</label>
            @{
                var media = ViewBag.MediaFiles as IEnumerable<string> ?? Enumerable.Empty<string>();
            }
            @if (media.Any())
            {
                <select asp-for="ImageUrl" class="form-select">
                    <option value="">-- Select an image --</option>
                    @foreach (var path in media)
                    {
                        <option value="@path" selected="@(Model?.ImageUrl == path ? "selected" : null)">@path</option>
                    }
                </select>
                <div class="mt-2">
                    <img id="image-preview" src="@(string.IsNullOrWhiteSpace(Model?.ImageUrl) ? "" : Model.ImageUrl)"
                        alt="Preview"
                        style="max-width:200px; display:@(string.IsNullOrWhiteSpace(Model?.ImageUrl) ? "none" : "block");" />
                </div>
            }
            else
            {
                <div class="text-secondary">No files found in /wwwroot/Media</div>
            }
            <span asp-validation-for="ImageUrl" class="text-danger"></span>
        </div>

        <div class="form-group" style="margin-top:1rem;">
            <input type="submit" value="Save" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </form>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function () {
            const select = document.querySelector('select[name="ImageUrl"]');
            const preview = document.getElementById('image-preview');
            if (select) {
                select.addEventListener('change', function () {
                    const val = this.value;
                    if (val && preview) {
                        preview.src = val;
                        preview.style.display = 'block';
                    } else if (preview) {
                        preview.src = '';
                        preview.style.display = 'none';
                    }
                });
            }

            const list = document.getElementById('details-list');
            const addBtn = document.getElementById('add-detail');

            function nextIndex() {
                const groups = list.querySelectorAll('.input-group[data-index]');
                if (groups.length === 0) return 0;
                const last = groups[groups.length - 1];
                return parseInt(last.getAttribute('data-index')) + 1;
            }

            function createGroup(i, value = '') {
                const div = document.createElement('div');
                div.className = 'input-group mb-2';
                div.setAttribute('data-index', i);
                div.innerHTML = `
                        <input type="hidden" name="Details[${i}].Id" value="" />
                        <input type="text" name="Details[${i}].Value" class="form-control" placeholder="Value" value="${value}">
                        <button type="button" class="btn btn-outline-danger remove-detail">Remove</button>
                    `;
                return div;
            }

            addBtn.addEventListener('click', function () {
                const i = nextIndex();
                list.appendChild(createGroup(i));
            });

            list.addEventListener('click', function (e) {
                if (e.target && e.target.classList.contains('remove-detail')) {
                    const group = e.target.closest('.input-group');
                    group?.remove();

                    // Reindex names for continuous indices
                    const groups = list.querySelectorAll('.input-group[data-index]');
                    groups.forEach((g, idx) => {
                        g.setAttribute('data-index', idx);
                        const idInput = g.querySelector('input[type="hidden"]');
                        const valInput = g.querySelector('input[type="text"]');
                        idInput.name = `Details[${idx}].Id`;
                        valInput.name = `Details[${idx}].Value`;
                    });
                }
            });
        })();
    </script>
}