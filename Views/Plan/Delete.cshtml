@model SportMania.Models.Plan
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@if (!SignInManager.IsSignedIn(User))
{
    <div class="alert alert-warning text-center" role="alert">
        Please <a asp-area="Identity" asp-page="/Account/Login" class="alert-link">log in</a> to delete this plan.
    </div>
}
else
{
    <h2>Delete Plan</h2>

    <h4>Are you sure you want to delete this plan?</h4>
    <div>
        <h4>@Model.Name</h4>
        <p>@Model.Description</p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="PlanId" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
}