@page "/transactions/success/{TransactionId:guid}"
@using BlazorApp.Services
@inject ITransactionService TransactionService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Payment Successful</PageTitle>

@if (transaction == null)
{
    <div class="container text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="text-secondary mt-3">Loading transaction details...</p>
    </div>
}
else
{
    <div class="container text-center py-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card bg-black text-white shadow-sm border-success">
                    <div class="card-body py-5">
                        <!-- Success Icon -->
                        <div class="mb-4">
                            <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-success" viewBox="0 0 16 16">
                                    <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
                                </svg>
                            </div>
                        </div>

                        <h1 class="card-title text-success fw-bold mb-3">Payment Successful!</h1>
                        <p class="lead text-secondary mb-4">Thank you for your purchase. Your transaction has been completed successfully.</p>
                        
                        <hr class="border-secondary">
                        
                        <!-- Transaction Details -->
                        <div class="bg-dark rounded p-4 my-4 text-start">
                            <h6 class="text-secondary mb-3">Transaction Details</h6>
                            @if (transaction.Plan != null)
                            {
                                <div class="row mb-2">
                                    <div class="col-5 text-secondary">Plan:</div>
                                    <div class="col-7 text-white">@transaction.Plan.Name</div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-5 text-secondary">Amount:</div>
                                    <div class="col-7 text-white">@transaction.Amount</div>
                                </div>
                            }
                            <div class="row">
                                <div class="col-5 text-secondary">Status:</div>
                                <div class="col-7">
                                    <span class="badge bg-success">@transaction.PaymentStatus</span>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(licenseKey))
                        {
                            <div class="alert alert-info mb-4">
                                <h6 class="mb-2">Your License Key:</h6>
                                <div class="bg-white text-dark p-3 rounded">
                                    <strong style="font-size: 1.2rem; letter-spacing: 2px;">@licenseKey</strong>
                                </div>
                                <p class="text-dark small mt-2 mb-0">Please save this key. You will need it to get your role in our Discord server.</p>
                            </div>
                        }

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-lg" @onclick="GoHome">
                                Back to Home
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid TransactionId { get; set; }

    private TransactionDto? transaction;
    private string? licenseKey;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadTransaction();
    }

    private async Task LoadTransaction()
    {
        try
        {
            transaction = await TransactionService.GetTransactionAsync(TransactionId);
            
            if (transaction == null)
            {
                errorMessage = "Transaction not found.";
            }
            else
            {
                // Get license key from transaction's Key navigation property
                licenseKey = transaction.Key?.LicenseKey;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading transaction: {ex.Message}";
            Console.WriteLine($"Error: {ex}");
        }
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }

    private void ViewTransactions()
    {
        Navigation.NavigateTo("/transactions");
    }
}
