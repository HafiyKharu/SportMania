@page "/transactions"
@using BlazorApp.Services
@inject ITransactionService TransactionService
@rendermode InteractiveServer

<PageTitle>Transaction History</PageTitle>

<div class="container py-5">
    <h1 class="mb-4 text-light">Transaction History</h1>

    @if (errorMessage != null)
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }

    <div class="card bg-dark text-white border-secondary">
        <div class="card-body">
            @if (transactions == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-secondary mt-3">Loading transactions...</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Transaction ID</th>
                                <th>Customer Email</th>
                                <th>Plan</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Bill Code</th>
                                <th>Guild ID</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (transactions.Count > 0)
                            {
                                @foreach (var transaction in transactions)
                                {
                                    <tr>
                                        <td><small>@transaction.TransactionId.ToString().Substring(0, 8)...</small></td>
                                        <td>@(transaction.Customer?.Email ?? "N/A")</td>
                                        <td>@(transaction.Plan?.Name ?? "N/A")</td>
                                        <td>@transaction.Amount</td>
                                        <td>
                                            <span class="badge @GetStatusBadgeClass(transaction.PaymentStatus)">
                                                @transaction.PaymentStatus
                                            </span>
                                        </td>
                                        <td>@(transaction.BillCode ?? "N/A")</td>
                                        <td>@transaction.GuildId</td>
                                        <td>@transaction.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-secondary py-5">
                                        No transactions found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<TransactionDto>? transactions;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadTransactions();
    }

    private async Task LoadTransactions()
    {
        try
        {
            transactions = await TransactionService.GetAllTransactionsAsync();
            errorMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading transactions: {ex.Message}";
            Console.WriteLine($"Error: {ex}");
        }
    }

    private string GetStatusBadgeClass(string status)
    {
        return status.ToLower() switch
        {
            "success" => "bg-success",
            "completed" => "bg-success",
            "pending" => "bg-warning text-dark",
            "failed" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}