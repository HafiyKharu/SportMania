@page "/plans/delete/{Id:guid}"
@using BlazorApp.Services
@inject IPlanService PlanService
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Delete Plan</PageTitle>

<h2 class="text-light mb-4">Delete Plan</h2>

@if (errorMessage != null)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

@if (plan == null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="text-secondary mt-3">Loading plan...</p>
    </div>
}
else
{
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">Are you sure you want to delete this plan?</h4>
        <hr>
        <p class="mb-0">This action cannot be undone.</p>
    </div>

    <div class="card bg-black text-white border-secondary mb-4">
        <div class="card-body">
            <h4 class="card-title text-light">@plan.Name</h4>
            <p class="card-text text-secondary">@plan.Description</p>
            <div class="d-flex align-items-baseline">
                <h5 class="text-primary me-2 mb-0">@plan.Price</h5>
                <small class="text-secondary">/ @plan.Duration</small>
            </div>

            @if (!string.IsNullOrWhiteSpace(plan.ImageUrl))
            {
                <div class="mt-3">
                    <img src="@plan.ImageUrl" alt="@plan.Name" style="max-width: 200px;" class="img-thumbnail">
                </div>
            }

            @if (plan.Details != null && plan.Details.Any())
            {
                <div class="mt-3">
                    <h6 class="text-light">Details:</h6>
                    <ul class="text-secondary">
                        @foreach (var detail in plan.Details)
                        {
                            <li>@detail.Value</li>
                        }
                    </ul>
                </div>
            }
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-danger" @onclick="HandleDelete" disabled="@isDeleting">
            @if (isDeleting)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Delete
        </button>
        <button class="btn btn-secondary" @onclick="Cancel" disabled="@isDeleting">Cancel</button>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private PlanDto? plan;
    private string? errorMessage;
    private bool isDeleting = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlan();
    }

    private async Task LoadPlan()
    {
        try
        {
            plan = await PlanService.GetPlanByIdAsync(Id);
            if (plan == null)
            {
                errorMessage = "Plan not found.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading plan: {ex.Message}";
        }
    }

    private async Task HandleDelete()
    {
        isDeleting = true;
        errorMessage = null;

        try
        {
            await PlanService.DeletePlanAsync(Id);
            Navigation.NavigateTo("/plans");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting plan: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/plans");
    }
}
