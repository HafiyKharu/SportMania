@page "/plans/create"
@using BlazorApp.Services
@inject IPlanService PlanService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Create Plan</PageTitle>

<h2 class="text-light mb-4">Create New Plan</h2>

@if (errorMessage != null)
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<EditForm Model="plan" OnValidSubmit="HandleCreate">
    <DataAnnotationsValidator />

    <div class="card bg-black text-white border-secondary mb-4">
        <div class="card-body">
            <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <InputText @bind-Value="plan.Name" class="form-control" id="name" />
                <ValidationMessage For="@(() => plan.Name)" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <InputTextArea @bind-Value="plan.Description" class="form-control" id="description" rows="3" />
                <ValidationMessage For="@(() => plan.Description)" class="text-danger" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label for="price" class="form-label">Price</label>
                    <InputText @bind-Value="plan.Price" class="form-control" id="price" />
                    <ValidationMessage For="@(() => plan.Price)" class="text-danger" />
                </div>

                <div class="col-md-6 mb-3">
                    <label for="duration" class="form-label">Duration</label>
                    <InputText @bind-Value="plan.Duration" class="form-control" id="duration" />
                    <ValidationMessage For="@(() => plan.Duration)" class="text-danger" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Details</label>
                @for (int i = 0; i < plan.Details.Count; i++)
                {
                    var index = i;
                    <div class="input-group mb-2">
                        <input type="text" @bind="plan.Details[index].Value" class="form-control" placeholder="Detail value" />
                        <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveDetail(index)">Remove</button>
                    </div>
                }
                <button type="button" class="btn btn-outline-primary btn-sm mt-2" @onclick="AddDetail">
                    Add Detail
                </button>
            </div>

            <div class="mb-3">
                <label class="form-label">Image</label>

                <div class="mb-2">
                    <label for="imageUpload" class="form-label text-secondary">Upload New Image</label>
                    <InputFile OnChange="HandleFileSelected" class="form-control" id="imageUpload" accept="image/*" />
                    @if (isUploading)
                    {
                        <div class="mt-2">
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span class="text-secondary">Uploading...</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(uploadError))
                    {
                        <div class="text-danger mt-2 small">@uploadError</div>
                    }
                    @if (!string.IsNullOrEmpty(uploadSuccess))
                    {
                        <div class="text-success mt-2 small">@uploadSuccess</div>
                    }
                </div>

                <label for="imageUrl" class="form-label text-secondary">Or select existing image</label>
                @if (mediaFiles != null && mediaFiles.Count > 0)
                {
                    <select @bind="plan.ImageUrl" class="form-select" id="imageUrl">
                        <option value="">-- Select an image --</option>
                        @foreach (var path in mediaFiles)
                        {
                            <option value="@path">@path</option>
                        }
                    </select>
                }
                else
                {
                    <div class="text-secondary small">No images found. Upload one above first.</div>
                }
                
                @if (!string.IsNullOrEmpty(plan.ImageUrl))
                {
                    <div class="mt-3">
                        <label class="form-label text-secondary">Preview:</label>
                        <div>
                            <img src="@plan.ImageUrl" alt="Preview" style="max-width: 200px; max-height: 200px;" class="img-thumbnail bg-dark" />
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
            @if (isSubmitting)
            {
                <span class="spinner-border spinner-border-sm me-2"></span>
            }
            Create
        </button>
        <button type="button" class="btn btn-outline-secondary" @onclick="Cancel">Cancel</button>
    </div>
</EditForm>

@code {
    private PlanDto plan = new() { Details = new List<PlanDetailDto> { new() } };
    private List<string>? mediaFiles;
    private string? errorMessage;
    private string? uploadError;
    private string? uploadSuccess;
    private bool isSubmitting = false;
    private bool isUploading = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadMediaFiles();
    }

    private async Task LoadMediaFiles()
    {
        try
        {
            mediaFiles = await PlanService.GetMediaPathsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading media files: {ex.Message}";
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadSuccess = null;
        uploadError = null;
        isUploading = true;

        try
        {
            var file = e.File;
            
            // Validate file size (max 5MB)
            if (file.Size > 5 * 1024 * 1024)
            {
                uploadError = "File size must be less than 5MB.";
                isUploading = false;
                return;
            }

            // Validate file type
            var allowedTypes = new[] { "image/jpeg", "image/jpg", "image/png", "image/gif", "image/webp" };
            if (!allowedTypes.Contains(file.ContentType.ToLower()))
            {
                uploadError = "Only image files (JPG, PNG, GIF, WEBP) are allowed.";
                isUploading = false;
                return;
            }

            // Save file
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            var imageUrl = await PlanService.SaveImageAsync(stream, file.Name);

            if (imageUrl != null)
            {
                plan.ImageUrl = imageUrl;
                uploadSuccess = "Image uploaded successfully!";
                
                // Add to media list without full reload
                mediaFiles ??= new List<string>();
                if (!mediaFiles.Contains(imageUrl))
                {
                    mediaFiles.Add(imageUrl);
                }
            }
            else
            {
                uploadError = "Failed to upload image.";
            }
        }
        catch (Exception ex)
        {
            uploadError = $"Error: {ex.Message}";
            Console.WriteLine($"Upload error: {ex}");
        }
        finally
        {
            isUploading = false;
        }
    }

    private void AddDetail()
    {
        plan.Details.Add(new PlanDetailDto());
    }

    private void RemoveDetail(int index)
    {
        if (plan.Details.Count > 1)
        {
            plan.Details.RemoveAt(index);
        }
    }

    private async Task HandleCreate()
    {
        isSubmitting = true;
        errorMessage = null;

        try
        {
            plan.PlanId = Guid.NewGuid();
            
            // Clear CreatedAt - Backend will set this
            plan.CreatedAt = null;
            plan.IsDeleted = false;
            
            // Ensure all detail IDs are set properly
            foreach (var detail in plan.Details)
            {
                detail.PlanDetailsId = Guid.NewGuid();
                detail.PlanId = plan.PlanId;
            }
            
            await PlanService.CreatePlanAsync(plan);
            Navigation.NavigateTo("/plans");
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating plan: {ex.Message}";
            Console.WriteLine($"Full error: {ex}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/plans");
    }
}
