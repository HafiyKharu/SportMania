@model IEnumerable<SportMania.Models.Plan>
@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager

@{
    ViewData["Title"] = "Available Plans";
}

@if (!SignInManager.IsSignedIn(User))
{
    <div class="alert alert-warning text-center" role="alert">
        Please <a asp-area="Identity" asp-page="/Account/Login" class="alert-link">log in</a> to view available plans.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>@ViewData["Title"]</h1>
        <a asp-action="Create" class="btn btn-primary">Create New Plan</a>
    </div>

    <div class="row">
        @foreach (var plan in Model)
        {
            <div class="col-lg-6 mb-4">
                <div class="card h-100 shadow-sm bg-black text-white">
                    <div class="row g-0 h-100">
                        @if (!string.IsNullOrWhiteSpace(plan.ImageUrl))
                        {
                            <div class="col-md-4 d-flex align-items-center justify-content-center p-2">
                                <a asp-action="Details" asp-route-id="@plan.PlanId">
                                    <img src="@plan.ImageUrl" class="img-fluid rounded" alt="@plan.Name"
                                        style="max-height: 150px; object-fit: cover;">
                                </a>
                            </div>
                        }
                        <div class="col-md-8">
                            <div class="card-body d-flex flex-column h-100">
                                <h5 class="card-title">@plan.Name</h5>
                                <p class="card-text flex-grow-1">@plan.Description</p>

                                <div class="d-flex align-items-baseline mb-3">
                                    <h3 class="card-text price me-2">@plan.Price</h3>
                                    <small>/ @plan.Duration</small>
                                </div>

                                <div class="mt-auto">
                                    <a asp-action="Details" asp-route-id="@plan.PlanId"
                                        class="btn btn-outline-primary btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@plan.PlanId"
                                        class="btn btn-outline-secondary btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@plan.PlanId"
                                        class="btn btn-outline-danger btn-sm">Delete</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}